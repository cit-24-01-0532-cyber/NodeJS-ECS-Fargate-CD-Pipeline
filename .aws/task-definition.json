{
    "family": "my-node-app-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "node-app-container",
            "image": "my-node-app",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp"
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::123456789012:role/ecs_task_execution_role"
}